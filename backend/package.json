{
  "name": "hrcloud-malaysia-backend",
  "version": "1.0.0",
  "description": "HRCloud Malaysia — PostgreSQL backend API",
  "main": "src/server.js",
  "scripts": {
    "start":     "node src/server.js",
    "dev":       "nodemon src/server.js",
    "migrate":   "node scripts/migrate.js",
    "seed":      "node scripts/seed.js",
    "setup":     "node scripts/migrate.js && node scripts/seed.js",
    "reset":     "node scripts/reset.js"
  },
  "dependencies": {
    "express":    "^4.18.2",
    "pg":         "^8.11.3",
    "bcryptjs":   "^2.4.3",
    "jsonwebtoken":"^9.0.2",
    "cors":       "^2.8.5",
    "dotenv":     "^16.3.1",
    "helmet":     "^7.1.0",
    "morgan":     "^1.10.0",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
